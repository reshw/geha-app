# .env.example
# Copy to .env and fill in with your actual values for local development
# DO NOT commit the .env file - it's in .gitignore

# Kakao
VITE_KAKAO_REST_API_KEY=your_kakao_key
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# Firebase (Client-side, safe to commit)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain
VITE_FIREBASE_PROJECT_ID=jh308-60114
VITE_FIREBASE_STORAGE_BUCKET=your_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_UPLOAD_PRESET=your_preset
VITE_CLOUDINARY_UPLOAD_PRESET_PRAISE=your_preset

# UI Settings
VITE_ENABLE_ERUDA=false
VITE_DISABLE_CONSOLE=false

# Netlify: Set these in Netlify UI (Site Settings > Environment Variables)
# DO NOT put these in this file
# - FIREBASE_PRIVATE_KEY
# - FIREBASE_CLIENT_EMAIL
# - FIREBASE_CLIENT_ID
# - NHN_APPKEY
# - NHN_SECRET_KEY
# - NHN_API_URL
# - NHN_PLUS_FRIEND_ID
# - NHN_SENDER_KEY
# - NHN_TEMPLATE_GUEST_CONFIRM
# - RESEND_API_KEY
# - OPENAI_API_KEY
